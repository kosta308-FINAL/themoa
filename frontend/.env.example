# 백엔드 API 주소. 개발에서는 http://localhost:8080으로 직접 호출한다
# (SecurityConfig의 CORS 설정이 http://localhost:5173 origin을 허용하는 것이 전제).
# 비워 두면 상대 경로 요청이 Vite 프록시(vite.config.js)를 타고 8080으로 전달된다.
# 배포에서는 nginx가 동일 origin에서 /api를 서빙하므로 비워 둔다.
VITE_API_BASE_URL=http://localhost:8080

# 로컬 정책 개발 도구를 로그인 없이 사용할 때만 true로 설정한다.
# 백엔드도 local profile + POLICY_LOCAL_TOOLS_ENABLED=true여야 한다.
VITE_POLICY_LOCAL_TOOLS_ENABLED=false
